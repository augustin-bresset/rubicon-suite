[options]
; Chemins d'addons
addons_path = /mnt/extra-addons,/mnt/external-addons/oca_currency,/usr/lib/python3/dist-packages/odoo/addons
db_host = db_demo
db_port = 5432
db_user = odoo
; Must match POSTGRES_PASSWORD in .env.demo
db_password = CHANGE_ME

http_interface = 0.0.0.0

dbfilter = ^rubicondemo$
without_demo = False

; SECURITY: Protects the database manager (/web/database/manager).
; Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
admin_passwd = CHANGE_ME
