<odoo>
  <!-- PDP Model Views: align with original PDP software -->
  <!-- list view for Models (Lobby/List) -->
  <record id="view_pdp_model_list" model="ir.ui.view">
    <field name="name">pdp.model.list</field>
    <field name="model">pdp.model</field>
    <field name="arch" type="xml">
      <list string="Models" editable="false">
        <field name="name"/>
        <field name="drawing_ref"/>
        <field name="quotation_ref"/>
      </list>
    </field>
  </record>

  <!-- Form view for Model details and tabs -->
  <record id="view_pdp_model_form" model="ir.ui.view">
    <field name="name">pdp.model.form</field>
    <field name="model">pdp.model</field>
    <field name="arch" type="xml">
      <form string="Product Definition and Pricing">
        <header>
          <button name="save" string="Save" type="object" class="btn-primary"/>
          <button name="action_margins" string="Margins" type="object" class="btn-secondary"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="drawing_ref"/>
            <field name="quotation_ref"/>
          </group>
          <notebook>
            <page string="Model Image">
              <field name="model_image" widget="image" options="{'size': (300,300)}"/>
            </page>
            <page string="Drawing">
              <field name="drawing_file"/>
            </page>
            <page string="Costing Summary">
              <field name="costing_summary_ids">
                <list editable="bottom">
                  <field name="margin"/>
                  <field name="purity"/>
                  <field name="metal_conv"/>
                  <field name="currency"/>
                  <field name="us_rate"/>
                  <field name="cost"/>
                  <field name="margin_amount"/>
                  <field name="price"/>
                </list>
              </field>
            </page>
            <page string="Weight Summary">
              <field name="weight_summary_ids">
                <list editable="bottom">
                  <field name="weight_before"/>
                  <field name="weight_after"/>
                  <field name="metal_weight"/>
                </list>
              </field>
            </page>
            <page string="Stones">
              <field name="stone_line_ids">
                <list editable="bottom">
                  <field name="line_num"/>
                  <field name="stone_id"/>
                  <field name="setting_cost"/>
                  <field name="rec_shape"/>
                  <field name="rec_size"/>
                  <field name="rec_weight"/>
                </list>
              </field>
            </page>
            <page string="Metals">
              <field name="metal_line_ids">
                <list editable="bottom">
                  <field name="metal_id"/>
                  <field name="quantity"/>
                  <field name="purity"/>
                </list>
              </field>
            </page>
            <page string="Labor etc.">
              <field name="labor_line_ids">
                <list editable="bottom">
                  <field name="labor_type"/>
                  <field name="cost"/>
                </list>
              </field>
            </page>
            <page string="Matching">
              <field name="matching_ids">
                <list editable="bottom">
                  <field name="matched_item"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action for PDP Models -->
  <record id="action_pdp_model" model="ir.actions.act_window">
    <field name="name">PDP Models</field>
    <field name="res_model">pdp.model</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Existing Stone Category and Type views -->
  <include file="your_module.view_pdp_stone_category.xml"/>
  <include file="your_module.view_pdp_stone_type.xml"/>

  <!-- Main menu items -->
  <menuitem id="menu_pdp_root" name="PDP" sequence="10"/>
  <menuitem id="menu_pdp_models" name="Models" parent="menu_pdp_root" action="action_pdp_model" sequence="20"/>
  <menuitem id="menu_pdp_refs" name="References" parent="menu_pdp_root" sequence="30"/>
  <menuitem id="menu_pdp_categories" name="Categories" parent="menu_pdp_refs" action="action_pdp_stone_category" sequence="10"/>
  <menuitem id="menu_pdp_types" name="Types" parent="menu_pdp_refs" action="action_pdp_stone_type" sequence="20"/>
  <menuitem id="menu_pdp_shapes" name="Shapes" parent="menu_pdp_refs" action="action_pdp_stone_shape" sequence="30"/>
  <menuitem id="menu_pdp_shades" name="Shades" parent="menu_pdp_refs" action="action_pdp_stone_shade" sequence="40"/>
  <menuitem id="menu_pdp_sizes" name="Sizes" parent="menu_pdp_refs" action="action_pdp_stone_size" sequence="50"/>
</odoo>
