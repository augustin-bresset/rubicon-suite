<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="pdp_frontend.metal_manage">
    <div class="o_action pdp-manage d-flex flex-column" style="height: 100%;">

        <!-- Top bar -->
        <div class="pdp-manage-topbar d-flex align-items-center gap-2 px-3 py-2 border-bottom">
            <span class="fw-bold fs-5 me-auto">Metals</span>
            <button
                class="btn btn-primary btn-sm"
                t-att-disabled="!state.isDirty"
                t-on-click="() => this.saveAll()">
                Save
                <t t-if="this.dirtyCount > 0">
                    (<t t-esc="this.dirtyCount"/>)
                </t>
            </button>
            <button class="btn btn-secondary btn-sm" t-on-click="() => this.addMetal()">
                Add Metal
            </button>
        </div>

        <!-- Metals table (resizable) -->
        <div class="p-3 border-bottom overflow-auto"
             t-att-style="'height:' + state.splitTopHeight + 'px; flex-shrink: 0;'">
            <table class="table table-sm table-hover pdp-manage-table">
                <thead>
                    <tr>
                        <th style="width: 90px;">Code</th>
                        <th style="width: 150px;">Name</th>
                        <th style="width: 110px;">Cost</th>
                        <th style="width: 120px;">Currency</th>
                        <th style="width: 100px;">Method</th>
                        <th style="width: 60px;" class="text-center">Plating</th>
                        <th style="width: 60px;" class="text-center">Gold</th>
                        <th style="width: 120px;">Default Purity</th>
                        <th style="width: 110px;">Type</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="state.metals" t-as="row" t-key="row._key">
                        <tr
                            t-att-class="(state.selectedMetalKey === row._key ? 'table-primary' : '') + (row._dirty ? ' table-warning' : '')"
                            t-on-click="() => this.selectMetal(row)"
                            style="cursor: pointer;">
                            <td>
                                <input
                                    type="text"
                                    class="form-control form-control-sm"
                                    t-att-value="row.code"
                                    t-on-input="(e) => this.onMetalFieldChange(row, 'code', e.target.value)"
                                    t-on-click.stop="() => {}"
                                />
                            </td>
                            <td>
                                <input
                                    type="text"
                                    class="form-control form-control-sm"
                                    t-att-value="row.name"
                                    t-on-input="(e) => this.onMetalFieldChange(row, 'name', e.target.value)"
                                    t-on-click.stop="() => {}"
                                />
                            </td>
                            <td>
                                <input
                                    type="number"
                                    step="0.01"
                                    class="form-control form-control-sm"
                                    t-att-value="row.cost"
                                    t-on-input="(e) => this.onMetalFieldChange(row, 'cost', e.target.value)"
                                    t-on-click.stop="() => {}"
                                />
                            </td>
                            <td t-on-click.stop="() => {}">
                                <select
                                    class="form-select form-select-sm"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'currency_id', +e.target.value)">
                                    <t t-foreach="this.currencies" t-as="c" t-key="c.id">
                                        <option
                                            t-att-value="c.id"
                                            t-att-selected="this.m2oId(row.currency_id) === c.id">
                                            <t t-esc="c.name"/>
                                        </option>
                                    </t>
                                </select>
                            </td>
                            <td t-on-click.stop="() => {}">
                                <select
                                    class="form-select form-select-sm"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'cost_method', e.target.value)">
                                    <option value="fixed" t-att-selected="row.cost_method === 'fixed'">Fixed</option>
                                    <option value="market" t-att-selected="row.cost_method === 'market'">Market</option>
                                </select>
                            </td>
                            <td class="text-center" t-on-click.stop="() => {}">
                                <input
                                    type="checkbox"
                                    t-att-checked="row.plating"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'plating', e.target.checked)"
                                />
                            </td>
                            <td class="text-center" t-on-click.stop="() => {}">
                                <input
                                    type="checkbox"
                                    t-att-checked="row.gold"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'gold', e.target.checked)"
                                />
                            </td>
                            <td t-on-click.stop="() => {}">
                                <select
                                    class="form-select form-select-sm"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'default_purity_id', +e.target.value || false)">
                                    <option value="">—</option>
                                    <t t-foreach="state.purities" t-as="pur" t-key="pur.id">
                                        <option
                                            t-att-value="pur.id"
                                            t-att-selected="this.m2oId(row.default_purity_id) === pur.id">
                                            <t t-esc="pur.code"/>
                                        </option>
                                    </t>
                                </select>
                            </td>
                            <td t-on-click.stop="() => {}">
                                <select
                                    class="form-select form-select-sm"
                                    t-on-change="(e) => this.onMetalFieldChange(row, 'purity_system', e.target.value || false)">
                                    <option value="">—</option>
                                    <option value="carat" t-att-selected="row.purity_system === 'carat'">Carat</option>
                                    <option value="millesimal" t-att-selected="row.purity_system === 'millesimal'">Millièmes</option>
                                </select>
                            </td>
                            <td t-on-click.stop="() => {}">
                                <button
                                    class="btn btn-sm btn-outline-danger"
                                    t-on-click.stop="() => this.removeMetal(row)">
                                    ✕
                                </button>
                            </td>
                        </tr>
                    </t>
                    <t t-if="state.metals.length === 0">
                        <tr>
                            <td colspan="9" class="text-center text-muted fst-italic py-3">
                                No metals. Click Add Metal to create one.
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>

        <!-- Resize handle -->
        <div
            style="height: 6px; background: #dee2e6; cursor: row-resize; flex-shrink: 0;"
            class="border-top border-bottom"
            t-on-mousedown="(e) => this.onResizeStart(e)"
        />

        <!-- Bottom tabs -->
        <div class="d-flex flex-column p-3" style="flex: 1 1 0; min-height: 0; overflow: hidden;">
            <!-- Tab nav -->
            <ul class="nav nav-tabs mb-2">
                <li class="nav-item">
                    <a
                        class="nav-link"
                        t-att-class="state.activeTab === 'conversion' ? 'active' : ''"
                        href="#"
                        t-on-click.prevent="() => this.setTab('conversion')">
                        Conversion Parameters
                    </a>
                </li>
                <li class="nav-item">
                    <a
                        class="nav-link"
                        t-att-class="state.activeTab === 'purities' ? 'active' : ''"
                        href="#"
                        t-on-click.prevent="() => this.setTab('purities')">
                        Purities
                    </a>
                </li>
            </ul>

            <!-- Conversion tab -->
            <t t-if="state.activeTab === 'conversion'">
                <div class="d-flex flex-column" style="flex: 1 1 0; min-height: 0; overflow: hidden;">
                    <t t-if="!this.selectedMetal">
                        <div class="text-muted fst-italic py-2">Select a metal above to manage its conversion parameters.</div>
                    </t>
                    <t t-else="">
                        <div class="d-flex align-items-center gap-2 mb-2 flex-shrink-0">
                            <span class="fw-semibold">Parameters for: <t t-esc="this.selectedMetal.code"/></span>
                            <button class="btn btn-secondary btn-sm ms-auto" t-on-click="() => this.addParameter()">
                                Add Parameter
                            </button>
                        </div>
                        <div class="overflow-auto" style="flex: 1 1 0;">
                            <table class="table table-sm table-hover pdp-manage-table">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Process Name</th>
                                        <th style="width: 120px;">Loss %</th>
                                        <th style="width: 120px;">Risk Factor</th>
                                        <th style="width: 130px;">Density Diff. %</th>
                                        <th style="width: 40px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="this.filteredParameters" t-as="row" t-key="row._key">
                                        <tr t-att-class="row._dirty ? 'table-warning' : ''">
                                            <td>
                                                <input
                                                    type="text"
                                                    class="form-control form-control-sm"
                                                    t-att-value="row.name"
                                                    t-on-input="(e) => this.onParamFieldChange(row, 'name', e.target.value)"
                                                />
                                            </td>
                                            <td>
                                                <input
                                                    type="number"
                                                    step="0.01"
                                                    class="form-control form-control-sm"
                                                    t-att-value="row.loss_percentage"
                                                    t-on-input="(e) => this.onParamFieldChange(row, 'loss_percentage', e.target.value)"
                                                />
                                            </td>
                                            <td>
                                                <input
                                                    type="number"
                                                    step="0.01"
                                                    class="form-control form-control-sm"
                                                    t-att-value="row.risk_factor"
                                                    t-on-input="(e) => this.onParamFieldChange(row, 'risk_factor', e.target.value)"
                                                />
                                            </td>
                                            <td>
                                                <input
                                                    type="number"
                                                    step="0.01"
                                                    class="form-control form-control-sm"
                                                    t-att-value="row.density_difference"
                                                    t-on-input="(e) => this.onParamFieldChange(row, 'density_difference', e.target.value)"
                                                />
                                            </td>
                                            <td>
                                                <button
                                                    class="btn btn-sm btn-outline-danger"
                                                    t-on-click.stop="() => this.removeParameter(row)">
                                                    ✕
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-if="this.filteredParameters.length === 0">
                                        <tr>
                                            <td colspan="5" class="text-center text-muted fst-italic py-3">
                                                No parameters for this metal.
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </div>
            </t>

            <!-- Purities tab -->
            <t t-if="state.activeTab === 'purities'">
                <div class="d-flex flex-column" style="flex: 1 1 0; min-height: 0; overflow: hidden;">
                    <div class="d-flex align-items-center gap-2 mb-2 flex-shrink-0">
                        <span class="fw-semibold">Metal Purities</span>
                        <button class="btn btn-secondary btn-sm ms-auto" t-on-click="() => this.addPurity()">
                            Add Purity
                        </button>
                    </div>
                    <div class="overflow-auto" style="flex: 1 1 0;">
                        <table class="table table-sm table-hover pdp-manage-table">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width: 150px;">Name (e.g. 18K)</th>
                                    <th style="width: 120px;">Percentage</th>
                                    <th style="width: 110px;">Type</th>
                                    <th style="width: 40px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.purities" t-as="row" t-key="row._key">
                                    <tr t-att-class="row._dirty ? 'table-warning' : ''">
                                        <td>
                                            <input
                                                type="text"
                                                class="form-control form-control-sm"
                                                t-att-value="row.code"
                                                t-on-input="(e) => this.onPurityFieldChange(row, 'code', e.target.value)"
                                            />
                                        </td>
                                        <td>
                                            <input
                                                type="number"
                                                step="0.1"
                                                class="form-control form-control-sm"
                                                t-att-value="row.percent"
                                                t-on-input="(e) => this.onPurityFieldChange(row, 'percent', e.target.value)"
                                            />
                                        </td>
                                        <td>
                                            <select
                                                class="form-select form-select-sm"
                                                t-on-change="(e) => this.onPurityFieldChange(row, 'purity_system', e.target.value || false)">
                                                <option value="">—</option>
                                                <option value="carat" t-att-selected="row.purity_system === 'carat'">Carat</option>
                                                <option value="millesimal" t-att-selected="row.purity_system === 'millesimal'">Millièmes</option>
                                            </select>
                                        </td>
                                        <td>
                                            <button
                                                class="btn btn-sm btn-outline-danger"
                                                t-on-click.stop="() => this.removePurity(row)">
                                                ✕
                                            </button>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="state.purities.length === 0">
                                    <tr>
                                        <td colspan="4" class="text-center text-muted fst-italic py-3">
                                            No purities defined.
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </div>

    </div>
</t>

</templates>
