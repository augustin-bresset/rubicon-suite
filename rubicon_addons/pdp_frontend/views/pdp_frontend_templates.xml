<odoo>
  <template id="pdp_frontend_page" name="PDP Frontend Page">
    <html lang="en">
      <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>PDP</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"/>
        <style type="text/css">
          .pdp-frontend-webpage {
            max-width: 1200px;
          }
          .pdp-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
          }
          .pdp-top-bar {
            display: flex;
            gap: 0.75rem;
            align-items: center;
            margin-bottom: 1rem;
          }
          .pdp-top-bar .form-select,
          .pdp-top-bar .form-control {
            min-width: 160px;
          }
          .pdp-panel-stack {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
          }
          /* FIX: Removed orphaned CSS line that was likely unintended or misplaced */
          /* margin-top: 0.25rem; */
          .pdp-table th,
          .pdp-table td {
            border: 1px solid #dee2e6;
            padding: 8px;
          }
          .pdp-table tfoot tr {
            background: #f1f3f5;
            font-weight: 600;
          }
          .pdp-footer-bar {
            margin-top: 1rem;
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
          }
          .pdp-footer-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
          }
        </style>
      </head>
      <body>
        <div class="container my-4 pdp-frontend-webpage">
          <div class="pdp-top-bar">
            <div class="flex-grow-1">
              <label class="form-label">Modèle</label>
              <select class="form-select">
                <option>Choisir un modèle</option>
                <option>R132</option>
                <option>R250</option>
              </select>
            </div>
            <div>
              <label class="form-label">&#160;</label>
              <button class="btn btn-primary w-100">Charger</button>
            </div>
            <div>
              <label class="form-label">Résultats</label>
              <select class="form-select">
                <option>3 éléments trouvés</option>
              </select>
            </div>
          </div>

          <div class="pdp-grid">
            <div class="pdp-panel-stack">
              <t t-foreach="range(0, 3)" t-as="panel">
                <div class="pdp-panel">
                  <strong class="d-block mb-2">Section <t t-esc="panel + 1"/></strong>
                  <div class="pdp-row">
                    <label class="form-label mb-0">Champ principal</label>
                    <input class="form-control" type="text" placeholder="Valeur"/>
                  </div>
                  <div class="pdp-row">
                    <label class="form-label mb-0">Liste</label>
                    <select class="form-select">
                      <option>Option 1</option>
                      <option>Option 2</option>
                    </select>
                  </div>
                  <div class="pdp-row">
                    <label class="form-label mb-0">Date/Heure</label>
                    <input class="form-control" type="datetime-local"/>
                  </div>
                  <div class="pdp-checkboxes mt-2">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" t-att-id="'check_a_%s' % panel"/>
                      <label class="form-check-label" t-att-for="'check_a_%s' % panel">Cocher A</label>
                    </div>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" t-att-id="'check_b_%s' % panel"/>
                      <label class="form-check-label" t-att-for="'check_b_%s' % panel">Cocher B</label>
                    </div>
                  </div>
                </div>
              </t>
            </div>

            <div class="pdp-preview-card">
              <div class="pdp-preview-image-wrapper">
                <span class="pdp-overlay-label">Texte en haut à droite</span>
                <img class="pdp-preview-image" src="https://via.placeholder.com/640x360" alt="Aperçu"/>
              </div>
              <div class="pdp-preview-actions">
                <button class="btn btn-outline-secondary btn-sm" type="button">Modèle</button>
                <button class="btn btn-outline-secondary btn-sm" type="button">Dessin</button>
                <button class="btn btn-outline-secondary btn-sm" type="button">Afficher</button>
                <button class="btn btn-outline-secondary btn-sm" type="button">Effacer</button>
              </div>
            </div>
          </div>

          <div class="pdp-tab-panel mt-3">
            <ul class="nav nav-tabs" id="pdpTab" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="materials-tab" data-bs-toggle="tab" data-bs-target="#materials" type="button" role="tab" aria-controls="materials" aria-selected="true">Matériaux</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="prices-tab" data-bs-toggle="tab" data-bs-target="#prices" type="button" role="tab" aria-controls="prices" aria-selected="false">Prix</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="catalog-tab" data-bs-toggle="tab" data-bs-target="#catalog" type="button" role="tab" aria-controls="catalog" aria-selected="false">Catalogue</button>
              </li>
            </ul>
            <div class="tab-content pdp-tab-content" id="pdpTabContent">
              <div class="tab-pane fade show active" id="materials" role="tabpanel" aria-labelledby="materials-tab">
                <div class="pdp-settings">
                  <label class="form-label mb-0">Type de métal</label>
                  <select class="form-select">
                    <option>Or blanc 18k</option>
                    <option>Or jaune 18k</option>
                    <option>Or rose 18k</option>
                  </select>
                  <label class="form-label mb-0">Grammage</label>
                  <input class="form-control" type="number" value="5.32"/>
                  <label class="form-label mb-0">Titre</label>
                  <input class="form-control" type="text" value="750"/>
                  <label class="form-label mb-0">Déchets</label>
                  <input class="form-control" type="number" value="2.5"/>
                </div>
              </div>
              <div class="tab-pane fade" id="prices" role="tabpanel" aria-labelledby="prices-tab">
                <div>
                  <label class="form-label">Prix de vente</label>
                  <table class="pdp-table">
                    <thead>
                      <tr>
                        <th>Groupe</th>
                        <th>Coût</th>
                        <th>Marge</th>
                        <th>TVA</th>
                        <th>Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>Standard</td>
                        <td>1,325.00</td>
                        <td>15%</td>
                        <td>20%</td>
                        <td>1,839.38</td>
                      </tr>
                      <tr>
                        <td>Pro</td>
                        <td>1,325.00</td>
                        <td>10%</td>
                        <td>20%</td>
                        <td>1,747.50</td>
                      </tr>
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="4">Total</td>
                        <td>1,793.44</td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
              </div>
              <div class="tab-pane fade" id="catalog" role="tabpanel" aria-labelledby="catalog-tab">
                <p class="mb-2">Info produit</p>
                <textarea class="form-control" rows="4">Détails du produit...</textarea>
              </div>
            </div>
          </div>

          <div class="pdp-footer-bar">
            <div class="pdp-footer-actions">
              <button class="btn btn-secondary" type="button">Copier</button>
              <button class="btn btn-outline-primary" type="button">Enregistrer</button>
              <button class="btn btn-outline-secondary" type="button">Prévision</button>
              <button class="btn btn-outline-secondary" type="button">Exporter</button>
              <button class="btn btn-outline-secondary" type="button">Imprimer</button>
              <button class="btn btn-outline-secondary" type="button">Exporter vers ERP</button>
              <button class="btn btn-outline-secondary" type="button">New</button>
              <button class="btn btn-outline-secondary" type="button">Reset</button>
            </div>
            <div class="pdp-footer-info text-muted">
              Déclinés&#160;– 1 unité
            </div>
          </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-H2UH7x/6KijLJrVN6a8GN28AL5soiceqd7qV671CyMfCVxMDamS0ajENPBIfl9xG" crossorigin="anonymous"></script>
      </body>
    </html>
  </template>
</odoo>