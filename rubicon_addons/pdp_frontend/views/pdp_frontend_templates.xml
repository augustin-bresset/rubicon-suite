<odoo>
  <template id="pdp_frontend_page" name="PDP Frontend Page">
    <html lang="en">
      <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>PDP</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"/>
        <style type="text/css">
          .pdp-frontend-webpage {
            max-width: 1200px;
          }
          .pdp-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
          }
          .pdp-top-bar {
            display: flex;
            gap: 0.75rem;
            align-items: center;
            margin-bottom: 1rem;
          }
          .pdp-top-bar .form-select,
          .pdp-top-bar .form-control {
            min-width: 160px;
          }
          .pdp-panel-stack {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
          }

          .pdp-table th,
          .pdp-table td {
            border: 1px solid #dee2e6;
            padding: 8px;
          }
          .pdp-table tfoot tr {
            background: #f1f3f5;
            font-weight: 600;
          }
          .pdp-footer-bar {
            margin-top: 1rem;
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
          }
          .pdp-footer-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
          }
        </style>
      </head>
      <body>
        <div class="container my-4 pdp-frontend-webpage">
          <!-- Top Bar -->
          <form action="/pdp" method="get" class="pdp-top-bar" id="pdpForm">
            <div class="flex-grow-1">
              <label class="form-label">Model</label>
              <select name="model_id" class="form-select" onchange="this.form.submit()">
                <option value="">Select a model...</option>
                <t t-foreach="all_models" t-as="m">
                  <option t-att-value="m.id" t-att-selected="str(m.id) == str(current_model_id)">
                    <t t-esc="m.code"/>
                  </option>
                </t>
              </select>
            </div>
            <div>
              <label class="form-label">Design</label>
              <t t-if="model_products">
                  <select class="form-select" onchange="window.location.href='/pdp/' + this.value">
                    <t t-foreach="model_products" t-as="p">
                        <option t-att-value="p.id" t-att-selected="p.id == product.id">
                            <t t-esc="p.code"/>
                        </option>
                    </t>
                  </select>
              </t>
              <t t-else="">
                 <input type="text" class="form-control" readonly="1" value="No Design"/>
              </t>
            </div>
            <div>
               <label class="form-label">&#160;</label>
               <a t-if="product" t-att-href="'/web#id=%s&amp;model=pdp.product' % product.id" class="btn btn-outline-secondary w-100" target="_blank">Open Backend</a>
            </div>
          </form>

          <t t-if="product">
            <div class="pdp-grid">
                <!-- Left Panel: Info -->
                <div class="pdp-panel-stack">
                    <div class="pdp-panel card card-body">
                        <strong>Product Details</strong>
                        <div class="pdp-row mt-2">
                           <label class="form-label mb-0">Code:</label> <span><t t-esc="product.code"/></span>
                        </div>
                         <div class="pdp-row">
                           <label class="form-label mb-0">Model:</label> <span><t t-esc="product.model_id.code"/></span>
                        </div>
                        <div class="pdp-row">
                           <label class="form-label mb-0">Metal:</label> <span><t t-esc="product.metal"/></span>
                        </div>
                    </div>
                </div>

                <!-- Right Panel: Image -->
                <div class="pdp-preview-card">
                  <div class="pdp-preview-image-wrapper">
                    <img class="pdp-preview-image" 
                         t-att-src="'/web/image?model=pdp.product.model&amp;id=%s&amp;field=picture_image' % product.model_id.id" 
                         alt="Product Image"/>
                  </div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="pdp-tab-panel mt-3">
              <ul class="nav nav-tabs" id="pdpTab" role="tablist">
                <li class="nav-item">
                  <button class="nav-link active" id="stones-tab" data-bs-toggle="tab" data-bs-target="#stones" type="button">Stones</button>
                </li>
                <li class="nav-item">
                  <button class="nav-link" id="metals-tab" data-bs-toggle="tab" data-bs-target="#metals" type="button">Metals</button>
                </li>
                <li class="nav-item">
                  <button class="nav-link" id="labor-tab" data-bs-toggle="tab" data-bs-target="#labor" type="button">Labor / Parts</button>
                </li>
                 <li class="nav-item">
                  <button class="nav-link" id="costing-tab" data-bs-toggle="tab" data-bs-target="#costing" type="button">Costing Summary</button>
                </li>
              </ul>
              
              <div class="tab-content pdp-tab-content p-3 border border-top-0" id="pdpTabContent">
                <!-- Stones Tab -->
                <div class="tab-pane fade show active" id="stones">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Stone</th>
                                <th>Pieces</th>
                                <th>Weight (ct)</th>
                                <th>Reshaped</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="product.stone_composition_id.stone_line_ids" t-as="line">
                                <td><t t-esc="line.stone_id.code if line.stone_id else ''"/></td>
                                <td><t t-esc="line.pieces"/></td>
                                <td><t t-esc="line.weight"/></td>
                                <td>
                                    <t t-if="line.reshaped_shape_id">
                                        <t t-esc="line.reshaped_shape_id.name"/> 
                                        (<t t-esc="line.reshaped_weight"/> ct)
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Metals Tab -->
                <div class="tab-pane fade" id="metals">
                     <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Metal</th>
                                <th>Version</th>
                                <th>Weight (g)</th>
                                <th>Purity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="product.model_id.metal_weights_ids" t-as="m">
                                <td><t t-esc="m.metal_id.name"/></td>
                                <td><t t-esc="m.metal_version"/></td>
                                <td><t t-esc="m.weight"/></td>
                                <td><t t-esc="m.purity_id.code"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Labor Tab -->
                <div class="tab-pane fade" id="labor">
                     <h5>Parts</h5>
                     <table class="table table-sm">
                        <thead>
                             <tr>
                                <th>Part Name</th>
                                <th>Quantity</th>
                             </tr>
                        </thead>
                        <tbody>
                             <tr t-foreach="product.part_ids" t-as="pp">
                                 <td><t t-esc="pp.part_id.name"/></td>
                                 <td><t t-esc="pp.quantity"/></td>
                             </tr>
                        </tbody>
                     </table>
                </div>
                
                 <!-- Costing Tab -->
                <div class="tab-pane fade" id="costing">
                    <t t-if="price_preview">
                      <div class="row">
                        <div class="col-md-6">
                            <h5>Details</h5>
                            <table class="table table-sm text-end">
                                <thead>
                                    <tr>
                                        <th class="text-start">Type</th>
                                        <th>Cost</th>
                                        <th>Margin</th>
                                        <th>Price</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="price_preview.line_ids" t-as="line">
                                        <td class="text-start"><t t-esc="line.type"/></td>
                                        <td><t t-esc="line.cost" t-options='{"widget": "monetary", "display_currency": price_preview.currency_id}'/></td>
                                        <td><t t-esc="line.margin" t-options='{"widget": "monetary", "display_currency": price_preview.currency_id}'/></td>
                                        <td><t t-esc="line.price" t-options='{"widget": "monetary", "display_currency": price_preview.currency_id}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6">
                           <h5>Total</h5>
                           <div class="card card-body bg-light">
                                <div class="d-flex justify-content-between">
                                    <span>Total Cost:</span>
                                    <strong t-field="price_preview.cost"/>
                                </div>
                                 <div class="d-flex justify-content-between">
                                    <span>Total Margin:</span>
                                    <strong t-field="price_preview.margin"/>
                                </div>
                                <hr/>
                                <div class="d-flex justify-content-between fs-5">
                                    <span>Final Price:</span>
                                    <strong t-field="price_preview.price" class="text-primary"/>
                                </div>
                           </div>
                        </div>
                      </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-warning">Pricing could not be calculated. Check server logs or configuration.</div>
                    </t>
                </div>

              </div>
            </div>
          </t>
          <t t-else="">
            <div class="alert alert-warning mt-4">
                Please select a Model to view its Products.
            </div>
          </t>

          <div class="pdp-footer-bar mt-4">
             <button class="btn btn-secondary">New</button>
             <button class="btn btn-secondary">Save</button>
             <button class="btn btn-secondary">Copy</button>
          </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-H2UH7x/6KijLJrVN6a8GN28AL5soiceqd7qV671CyMfCVxMDamS0ajENPBIfl9xG" crossorigin="anonymous"></script>
      </body>
    </html>
  </template>
</odoo>