<odoo>
  <!-- PDP Workspace action (used by client tag) -->
  <record id="action_pdp_frontend_workspace" model="ir.actions.client">
    <field name="name">PDP Workspace</field>
    <field name="tag">pdp_frontend.workspace</field>
  </record>

  <!-- Root menu -->
  <menuitem id="menu_pdp_frontend_root" name="PDP" action="action_pdp_frontend_workspace" sequence="1"/>

  <!-- ============ Manage ============ -->
  <menuitem id="menu_pdp_frontend_manage"
            name="Manage"
            parent="menu_pdp_frontend_root"
            sequence="10"/>


  <record id="action_pdp_stone_manage" model="ir.actions.client">
    <field name="name">Stones and Diamonds</field>
    <field name="tag">pdp_frontend.stone_manage</field>
  </record>
  <menuitem id="menu_pdp_manage_stones"
            name="Stones and Diamonds"
            parent="menu_pdp_frontend_manage"
            action="action_pdp_stone_manage"
            sequence="10"/>

  <record id="action_pdp_metal_manage" model="ir.actions.client">
    <field name="name">Metals</field>
    <field name="tag">pdp_frontend.metal_manage</field>
  </record>
  <menuitem id="menu_pdp_manage_metals"
            name="Metals"
            parent="menu_pdp_frontend_manage"
            action="action_pdp_metal_manage"
            sequence="15"/>

  <record id="action_pdp_parts_manage" model="ir.actions.client">
    <field name="name">Parts</field>
    <field name="tag">pdp_frontend.parts_manage</field>
  </record>
  <menuitem id="menu_pdp_manage_parts"
            name="Parts"
            parent="menu_pdp_frontend_manage"
            action="action_pdp_parts_manage"
            sequence="20"/>

  <record id="action_pdp_margins_manage" model="ir.actions.client">
    <field name="name">Margins</field>
    <field name="tag">pdp_frontend.margins_manage</field>
  </record>
  <menuitem id="menu_pdp_manage_margins"
            name="Margins"
            parent="menu_pdp_frontend_manage"
            action="action_pdp_margins_manage"
            sequence="25"/>

  <record id="action_pdp_categories_manage" model="ir.actions.client">
    <field name="name">Ornament Categories</field>
    <field name="tag">pdp_frontend.categories_manage</field>
  </record>
  <menuitem id="menu_pdp_manage_categories"
            name="Ornament Categories"
            parent="menu_pdp_frontend_manage"
            action="action_pdp_categories_manage"
            sequence="30"/>


  <!-- ============ Tools ============ -->
  <menuitem id="menu_pdp_frontend_tools"
            name="Tools"
            parent="menu_pdp_frontend_root"
            sequence="15"/>

  <menuitem id="menu_pdp_frontend_price_preview"
            name="Price Preview"
            parent="menu_pdp_frontend_tools"
            action="pdp_price.action_pdp_price_preview_wizard"
            sequence="1"/>

  <record id="action_pdp_product_stone_zero_weight" model="ir.actions.act_window">
    <field name="name">Stones with 0 Weight</field>
    <field name="res_model">pdp.product.stone</field>
    <field name="view_mode">list,form</field>
    <field name="domain">['|', ('weight', '=', False), ('weight', 'in', ['0', '0.0', '0.00', ''])]</field>
  </record>

  <menuitem id="menu_pdp_frontend_reports"
            name="Reports"
            parent="menu_pdp_frontend_tools"
            sequence="10"/>

  <menuitem id="menu_pdp_report_stone_zero_weight"
            name="Stones (0 Weight)"
            parent="menu_pdp_frontend_reports"
            action="action_pdp_product_stone_zero_weight"
            sequence="1"/>

  <!-- ============ Settings ============ -->
  <menuitem id="menu_pdp_frontend_settings"
            name="Settings"
            parent="menu_pdp_frontend_root"
            sequence="20"/>

  <menuitem id="menu_pdp_settings_currency"
            name="Currency Rates"
            parent="menu_pdp_frontend_settings"
            action="action_pdp_currency_setting"
            sequence="1"/>

  <menuitem id="menu_pdp_settings_uom"
            name="Units of Measure"
            parent="menu_pdp_frontend_settings"
            action="rubicon_uom.action_rubicon_uom_category"
            sequence="2"/>

  <!-- ============ Odoo Manager (Technical Features only) ============ -->
  <!-- Visible uniquement avec "Technical Features" activé sur le profil utilisateur -->
  <menuitem id="menu_pdp_odoo_manager"
            name="Odoo Manager"
            parent="menu_pdp_frontend_root"
            groups="base.group_no_one"
            sequence="99"/>

  <!-- pdp_metal -->
  <menuitem id="menu_odoo_mgr_metal" name="Metals" parent="menu_pdp_odoo_manager" sequence="10"/>
  <menuitem id="menu_odoo_mgr_metal_metals"    name="Metals"       parent="menu_odoo_mgr_metal" action="pdp_metal.action_pdp_metal"         sequence="1"/>
  <menuitem id="menu_odoo_mgr_metal_purities"  name="Purities"     parent="menu_odoo_mgr_metal" action="pdp_metal.action_pdp_metal_purity"  sequence="2"/>
  <menuitem id="menu_odoo_mgr_metal_parts"     name="Parts"        parent="menu_odoo_mgr_metal" action="pdp_metal.action_pdp_part"          sequence="3"/>
  <menuitem id="menu_odoo_mgr_metal_partcosts" name="Part Costs"   parent="menu_odoo_mgr_metal" action="pdp_metal.action_pdp_part_cost"     sequence="4"/>

  <!-- pdp_stone -->
  <menuitem id="menu_odoo_mgr_stone" name="Stones" parent="menu_pdp_odoo_manager" sequence="20"/>
  <menuitem id="menu_odoo_mgr_stone_cats"     name="Categories"   parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_category" sequence="1"/>
  <menuitem id="menu_odoo_mgr_stone_types"    name="Types"        parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_type"     sequence="2"/>
  <menuitem id="menu_odoo_mgr_stone_shapes"   name="Shapes"       parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_shape"   sequence="3"/>
  <menuitem id="menu_odoo_mgr_stone_shades"   name="Shades"       parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_shade"   sequence="4"/>
  <menuitem id="menu_odoo_mgr_stone_sizes"    name="Sizes"        parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_size"    sequence="5"/>
  <menuitem id="menu_odoo_mgr_stone_costs"    name="Unit Costs"   parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone"         sequence="6"/>
  <menuitem id="menu_odoo_mgr_stone_weights"  name="Unit Weights" parent="menu_odoo_mgr_stone" action="pdp_stone.action_pdp_stone_weight"  sequence="7"/>

  <!-- pdp_labor -->
  <menuitem id="menu_odoo_mgr_labor" name="Labor" parent="menu_pdp_odoo_manager" sequence="30"/>
  <menuitem id="menu_odoo_mgr_labor_types"      name="Labor Types"           parent="menu_odoo_mgr_labor" action="pdp_labor.action_pdp_labor_type"          sequence="1"/>
  <menuitem id="menu_odoo_mgr_labor_cost_model" name="Labor Costs (Model)"   parent="menu_odoo_mgr_labor" action="pdp_labor.action_pdp_labor_cost_model"    sequence="2"/>
  <menuitem id="menu_odoo_mgr_labor_cost_prod"  name="Labor Costs (Product)" parent="menu_odoo_mgr_labor" action="pdp_labor.action_pdp_labor_cost_product"  sequence="3"/>
  <menuitem id="menu_odoo_mgr_addon_types"      name="Addon Types"           parent="menu_odoo_mgr_labor" action="pdp_labor.action_pdp_addon_type"          sequence="4"/>
  <menuitem id="menu_odoo_mgr_addon_costs"      name="Addon Costs"           parent="menu_odoo_mgr_labor" action="pdp_labor.action_pdp_addon_cost"          sequence="5"/>

  <!-- pdp_product -->
  <menuitem id="menu_odoo_mgr_product" name="Products" parent="menu_pdp_odoo_manager" sequence="40"/>
  <menuitem id="menu_odoo_mgr_prod_cats"       name="Categories"         parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_category"          sequence="1"/>
  <menuitem id="menu_odoo_mgr_prod_models"     name="Models"             parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_model"             sequence="2"/>
  <menuitem id="menu_odoo_mgr_prod_products"   name="Products"           parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product"                   sequence="3"/>
  <menuitem id="menu_odoo_mgr_prod_metals"     name="Model Metals"       parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_model_metal"       sequence="4"/>
  <menuitem id="menu_odoo_mgr_prod_parts"      name="Product Parts"      parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_part"              sequence="5"/>
  <menuitem id="menu_odoo_mgr_prod_stones"     name="Product Stones"     parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_stone"             sequence="6"/>
  <menuitem id="menu_odoo_mgr_prod_matching"   name="Model Matching"     parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_model_matching"    sequence="7"/>
  <menuitem id="menu_odoo_mgr_prod_stone_comp" name="Stone Composition"  parent="menu_odoo_mgr_product" action="pdp_product.action_pdp_product_stone_composition" sequence="8"/>

  <!-- pdp_picture -->
  <menuitem id="menu_odoo_mgr_picture"  name="Pictures" parent="menu_pdp_odoo_manager" sequence="50"/>
  <menuitem id="menu_odoo_mgr_pictures" name="Pictures" parent="menu_odoo_mgr_picture" action="pdp_picture.action_pdp_picture" sequence="1"/>


</odoo>
