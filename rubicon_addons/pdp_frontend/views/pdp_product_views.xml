<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pdp_product_form_custom" model="ir.ui.view">
        <field name="name">pdp.product.form.custom</field>
        <field name="model">pdp.product</field>
        <field name="arch" type="xml">
            <form string="PDP Product">
                <sheet>
                    <!-- Top Section: Grid Layout -->
                    <div class="row mb-3">
                        <!-- Left: Product Details -->
                        <div class="col-md-6 border-end pe-4">
                            <h1 class="mb-3">
                                <field name="code" placeholder="Product Code"/>
                            </h1>
                            <group>
                                <field name="category_id"/>
                                <field name="model_id" context="{'show_image': True}"/>
                                <field name="stone_composition_id"/>
                                <field name="metal"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="in_collection" widget="boolean_toggle"/>
                                <field name="create_date" widget="date"/>
                                <field name="remark"/>
                            </group>
                        </div>
                        
                        <!-- Right: Model Images -->
                        <div class="col-md-6 ps-4 bg-light d-flex flex-column align-items-center justify-content-center" style="min-height: 250px;">
                            <field name="model_id" widget="image" options="{'preview_image': 'drawing'}" class="img-fluid rounded border shadow-sm mb-2" readonly="1" invisible="not model_id"/>
                            <!-- Assuming model_id has an image field, otherwise we might need a related field -->
                            <div class="text-muted small text-center" invisible="not model_id">
                                Model Drawing / Picture
                            </div>
                            <div class="text-muted fst-italic text-center" invisible="model_id">
                                Select a model to view images.
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Section: Notebook -->
                    <notebook>
                        <page name="costing" string="Costing Summary">
                            <!-- TODO: Add costing fields here once identified -->
                            <div class="text-muted p-4 text-center">Costing fields to be mapped.</div>
                        </page>
                        <page name="stones" string="Stones">
                            <field name="stone_line_ids" mode="list">
                                <list string="Stones" editable="bottom">
                                    <field name="stone_id"/>
                                    <field name="pieces"/>
                                    <field name="weight"/>
                                    <field name="reshaped_shape_id" optional="hide"/>
                                    <field name="reshaped_weight" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page name="weight" string="Weight Summary">
                             <group col="2">
                                 <group>
                                     <field name="total_stone_weight" readonly="1"/>
                                 </group>
                             </group>
                        </page>
                        <page name="metals" string="Metals">
                            <!-- Metals list usually comes from model or product parts -->
                            <div class="text-muted p-4 text-center">Metal components to be mapped.</div>
                        </page>
                        <page name="labor" string="Labor etc.">
                             <div class="text-muted p-4 text-center">Labor operations to be mapped.</div>
                        </page>
                        <page name="matching" string="Matching">
                             <div class="text-muted p-4 text-center">Matching models to be mapped.</div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- override the action to ensure it uses our view -->
    <record id="pdp_product.action_pdp_product" model="ir.actions.act_window">
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('pdp_product.view_pdp_product_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('pdp_frontend.view_pdp_product_form_custom')})]"/>
    </record>

</odoo>
