<odoo>
  <record id="view_pdp_product_form_frontend" model="ir.ui.view">
    <field name="name">pdp.product.form.frontend</field>
    <field name="model">pdp.product</field>
    <field name="arch" type="xml">
      <form string="Product Definition" create="true" class="o_form_full_width">
        <header>
          <!-- <button name="action_make_blank" string="Make Blank" type="object" class="btn-primary"/>
          <button name="action_copy_model" string="Copy" type="object"/> -->
          <button name="%(pdp_price.action_pdp_price_preview_wizard)d"
                  type="action"
                  context="{'default_product_id': id}"
                  string="Preview Price"
                  class="btn-secondary"/>
        </header>
        <sheet>
          <div class="pdp-frontend-layout">
            <div class="pdp-frontend-top">
              <group col="2" class="pdp-frontend-model">
                <group string="Model" colspan="2">
                  <field name="model_id"/>
                  <field name="code" string="Design Ref#"/>
                </group>
              </group>

              <group string="Designs">
                <field name="frontend_variant_ids" class="pdp-variant-list">
                  <list create="false" editable="bottom">
                    <field name="code"/>
                    <field name="category_id"/>
                    <field name="create_date"/>
                    <field name="active"/>
                    <field name="in_collection"/>
                  </list>
                </field>
              </group>

              <div class="pdp-frontend-preview">
                <field name="model_picture_image" widget="image" class="pdp-preview-image" nolabel="1"/>
                <div class="pdp-preview-overlay">
                  <label string="Design" for="code" class="o_form_label"/>
                  <field name="code" readonly="1" class="oe_inline"/>
                </div>
                  
                <div class="pdp-preview-price">
                  <span class="o_form_label">Total Price</span>
                  <field name="frontend_total_price" readonly="1" class="oe_inline"/>
                </div>

                <div class="pdp-preview-actions">
                  <button name="action_frontend_preview_reset" string="Model" type="object" class="btn-secondary"/>
                  <button name="action_frontend_preview_reset" string="Drawing" type="object" class="btn-secondary"/>
                  <button name="action_frontend_preview_reset" string="Show" type="object" class="btn-secondary"/>
                  <button name="action_frontend_preview_reset" string="Clear" type="object" class="btn-secondary"/>
                </div>
              </div>
            </div>
            <div class="pdp-frontend-bottom">
              <group string="Pricing Parameters" class="pdp-pricing-params" col="2">
                <group>
                  <field name="frontend_margin_id"/>
                  <field name="frontend_purity_id"/>
                  <field name="frontend_metal_conversion"/>
                </group>
                <group>
                  <field name="frontend_currency_id"/>
                  <field name="frontend_usd_rate" readonly="1"/>
                  <field name="frontend_date"/>
                </group>
              </group>

              <div class="pdp-cost-breakdown" colspan="2">
                <div class="o_form_label">Cost Breakdown</div>
                <div class="pdp-cost-table">
                  <div class="pdp-cost-row pdp-cost-header">
                    <span class="pdp-cell pdp-cell-label"></span>
                    <span class="pdp-cell">Cost</span>
                    <span class="pdp-cell">Margin</span>
                    <span class="pdp-cell">Price</span>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Metal</span>
                    <field name="frontend_metal_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_metal_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_metal_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Stone</span>
                    <field name="frontend_stone_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_stone_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_stone_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Setting</span>
                    <field name="frontend_labor_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_labor_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_labor_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Labor</span>
                    <field name="frontend_labor_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_labor_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_labor_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Misc</span>
                    <field name="frontend_misc_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_misc_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_misc_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row">
                    <span class="pdp-cell pdp-cell-label">Parts</span>
                    <field name="frontend_parts_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_parts_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_parts_price" readonly="1" class="pdp-cell"/>
                  </div>
                  <div class="pdp-cost-row pdp-cost-total">
                    <span class="pdp-cell pdp-cell-label">Net</span>
                    <field name="frontend_total_cost" readonly="1" class="pdp-cell"/>
                    <field name="frontend_total_margin" readonly="1" class="pdp-cell"/>
                    <field name="frontend_total_price" readonly="1" class="pdp-cell"/>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </sheet>
      </form>
    </field>
  </record>
</odoo>