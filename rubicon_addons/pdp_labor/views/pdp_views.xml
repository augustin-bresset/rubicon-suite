<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Labor Types -->
  <record id="view_pdp_labor_list" model="ir.ui.view">
    <field name="name">pdp.labor.type.list</field>
    <field name="model">pdp.labor.type</field>
    <field name="arch" type="xml">
      <list string="Labor Types">
        <field name="code"/>
        <field name="name"/>
      </list>
    </field>
  </record>

 <!-- Addon Types  -->
 <record id="view_pdp_addon_list" model="ir.ui.view">
    <field name="name">pdp.addon.type.list</field>
    <field name="model">pdp.addon.type</field>
    <field name="arch" type="xml">
      <list string="Addon Types">
        <field name="code"/>
        <field name="name"/>
      </list>
    </field>
  </record>

 <!-- Addon Costs  -->
 <record id="view_pdp_addon_cost_list" model="ir.ui.view">
    <field name="name">pdp.addon.cost.list</field>
    <field name="model">pdp.addon.cost</field>
    <field name="arch" type="xml">
      <list string="Addon Costs">
        <field name="product_id"/>
        <field name="addon_id"/>
        <field name="cost" />
        <field name="currency_id" />
      </list>
    </field>
  </record>

 <!-- Labor Costs (Model)  -->
 <record id="view_pdp_labor_cost_model_list" model="ir.ui.view">
    <field name="name">pdp.labor.cost.model.list</field>
    <field name="model">pdp.labor.cost.model</field>
    <field name="arch" type="xml">
      <list string="Labor Costs (Model)">
        <field name="model_id"/>
        <field name="labor_id"/>
        <field name="cost" />
        <field name="currency_id" />

      </list>
    </field>
  </record>

  <!-- Labor Costs (Product)  -->
 <record id="view_pdp_labor_cost_product_list" model="ir.ui.view">
    <field name="name">pdp.labor.cost.product.list</field>
    <field name="model">pdp.labor.cost.product</field>
    <field name="arch" type="xml">
      <list string="Labor Costs (Product)">
        <field name="product_id"/>
        <field name="labor_id"/>
        <field name="cost" />
        <field name="currency_id" />
      </list>
    </field>
  </record>

  <!-- Labor Settings -->
  <record id="action_pdp_labor_settings" model="ir.actions.act_window">
    <field name="name">Labor Settings</field>
    <field name="res_model">pdp.labor.settings</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_pdp_labor_settings_form" model="ir.ui.view">
    <field name="name">pdp.labor.settings.form</field>
    <field name="model">pdp.labor.settings</field>
    <field name="arch" type="xml">
      <form string="Labor Settings">
        <sheet>
          <group>
            <field name="default_labor_currency_id"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Stone Setting Types -->
  <record id="action_pdp_stone_setting_type" model="ir.actions.act_window">
    <field name="name">Setting Types</field>
    <field name="res_model">pdp.stone.setting.type</field>
    <field name="view_mode">list</field>
  </record>

  <record id="view_pdp_stone_setting_type_list" model="ir.ui.view">
    <field name="name">pdp.stone.setting.type.list</field>
    <field name="model">pdp.stone.setting.type</field>
    <field name="arch" type="xml">
      <list string="Setting Types" editable="bottom">
        <field name="name"/>
        <field name="cost"/>
      </list>
    </field>
  </record>


</odoo>
