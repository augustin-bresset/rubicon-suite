<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Tab on PDP Product Model -->
  <record id="view_pdp_product_model_form_pictures_inherit" model="ir.ui.view">
    <field name="name">pdp.product.model.form.pictures.inherit</field>
    <field name="model">pdp.product.model</field>
    <field name="inherit_id" ref="pdp_product.view_pdp_product_model_form"/>
    <field name="arch" type="xml">
      <notebook position="inside">
        <page string="Picture">
          <group>
            <field name="picture_image" widget="image" class="oe_avatar"/>
          </group>
        </page>
      </notebook>
    </field>
  </record>

  <!-- Tab on PDP Product -->
  <record id="view_pdp_product_form_pictures_inherit" model="ir.ui.view">
    <field name="name">pdp.product.form.pictures.inherit</field>
    <field name="model">pdp.product</field>
    <field name="inherit_id" ref="pdp_frontend.view_pdp_product_form_frontend"/>
    <field name="arch" type="xml">
      <notebook position="inside">
        <page string="Model Picture">
          <group>
            <field name="model_id" invisible="1"/>
            <field name="model_id.picture_image" widget="image" class="oe_avatar"/>
          </group>
        </page>
      </notebook>
    </field>
  </record>

</odoo>