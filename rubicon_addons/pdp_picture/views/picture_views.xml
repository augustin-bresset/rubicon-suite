<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Action & menu -->
  <record id="action_pdp_picture" model="ir.actions.act_window">
    <field name="name">Pictures</field>
    <field name="res_model">pdp.picture</field>
    <field name="view_mode">tree,form</field>
    <field name="context">{}</field>
  </record>

  <!-- Place this submenu under PDP root if you already have a root menu in pdp_frontend -->
  <menuitem id="menu_pdp_picture_root"
            name="Pictures"
            parent="pdp_frontend.menu_pdp_root"
            action="action_pdp_picture"
            sequence="50"/>

  <!-- List view -->
  <record id="view_pdp_picture_tree" model="ir.ui.view">
    <field name="name">pdp.picture.tree</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <tree string="Pictures" create="true" delete="true">
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="kind"/>
        <field name="model_id"/>
        <field name="model_code"/>
        <field name="filename"/>
        <field name="code"/>
        <field name="active"/>
      </tree>
    </field>
  </record>

  <!-- Search view -->
  <record id="view_pdp_picture_search" model="ir.ui.view">
    <field name="name">pdp.picture.search</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <search string="Search Pictures">
        <field name="name"/>
        <field name="model_id"/>
        <field name="model_code"/>
        <filter name="kind_sketch" string="Sketch" domain="[('kind','=','sketch')]"/>
        <filter name="kind_snapshot" string="Snapshot" domain="[('kind','=','snapshot')]"/>
        <filter name="kind_render" string="Render" domain="[('kind','=','render')]"/>
        <group expand="0" string="Group By">
          <filter name="group_model" string="Model" context="{'group_by': 'model_id'}"/>
          <filter name="group_kind" string="Type" context="{'group_by': 'kind'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Form view -->
  <record id="view_pdp_picture_form" model="ir.ui.view">
    <field name="name">pdp.picture.form</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <form string="Picture">
        <sheet>
          <group>
            <field name="name"/>
            <field name="kind"/>
            <field name="sequence"/>
            <field name="active"/>
          </group>
          <group>
            <field name="model_id"/>
            <field name="model_code" readonly="1"/>
            <field name="code"/>
            <field name="filename"/>
            <field name="checksum" readonly="1"/>
          </group>
          <group>
            <field name="image" widget="image" class="oe_avatar"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
