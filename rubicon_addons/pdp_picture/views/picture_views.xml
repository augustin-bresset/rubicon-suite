<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Action & menu -->
  <record id="action_pdp_picture" model="ir.actions.act_window">
    <field name="name">Pictures</field>
    <field name="res_model">pdp.picture</field>
    <field name="view_mode">kanban,list,form</field>
  </record>


  <menuitem id="menu_pdp_root"
            name="PDP Pictures"
            parent="pdp_product.menu_pdp_root"
            sequence="50"/>

  <menuitem id="menu_pdp_picture_root"
            name="Pictures"
            parent="menu_pdp_root"
            action="action_pdp_picture"
            sequence="10"/>

  <!-- Kanban -->
  <record id="view_pdp_picture_kanban" model="ir.ui.view">
    <field name="name">pdp.picture.kanban</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <kanban>
        <templates>
          <t t-name="card">
            <div class="o_kanban_record">
              <field name="image" widget="image" class="oe_avatar" width="160" height="160"/>
              <div class="o_kanban_primary_bottom">
                <strong><field name="scope"/></strong>
                <span> — </span>
                <field name="product_ids"/>
              </div>
              <div><field name="filename"/></div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- List -->
  <record id="view_pdp_picture_list" model="ir.ui.view">
    <field name="name">pdp.picture.list</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <list string="Pictures">
        <field name="scope"/>
        <field name="product_ids" widget="many2many_tags"/>
        <field name="filename"/>
        <field name="drawing_filename"/>
        <field name="source_date"/>
        <field name="checksum"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <!-- Search -->
  <record id="view_pdp_picture_search" model="ir.ui.view">
    <field name="name">pdp.picture.search</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <search>
        <field name="product_ids"/>
        <field name="filename"/>
        <filter name="filter_model_scope" string="Model scope" domain="[('scope','=','model')]"/>
        <filter name="filter_product_scope" string="Product scope" domain="[('scope','=','product')]"/>
        <filter name="filter_has_drawing" string="Has Drawing" domain="[('drawing_filename','!=',False)]"/>
        <filter name="filter_orphans" string="Orphans" domain="[('product_ids','=',False)]"/>
        <filter name="filter_active" string="Active" domain="[('active','=',True)]"/>
        <filter name="filter_inactive" string="Archived" domain="[('active','=',False)]"/>
        <separator/>
        <filter name="grp_scope" string="Group by Scope" context="{'group_by': 'scope'}"/>
        <filter name="grp_active" string="Group by Active" context="{'group_by': 'active'}"/>
      </search>
    </field>
  </record>

  <!-- Form -->
  <record id="view_pdp_picture_form" model="ir.ui.view">
    <field name="name">pdp.picture.form</field>
    <field name="model">pdp.picture</field>
    <field name="arch" type="xml">
      <form string="Picture">
        <sheet>
          <group>
            <group string="Classification">
              <field name="scope" readonly="1"/>
              <field name="product_ids" widget="many2many_tags" options="{'no_create': True}"/>
              <field name="active"/>
            </group>
            <group string="Traceability">
              <field name="filename"/>
              <field name="drawing_filename" readonly="1"/>
              <field name="source_date" readonly="1"/>
              <field name="checksum" readonly="1"/>
            </group>
          </group>
          <group string="Photo">
            <field name="image" widget="image" class="oe_avatar" nolabel="1"/>
          </group>
          <group string="Technical Drawing">
            <field name="drawing" widget="image" class="oe_avatar" nolabel="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
