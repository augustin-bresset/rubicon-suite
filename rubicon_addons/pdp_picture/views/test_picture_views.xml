<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vue formulaire du wizard -->
  <record id="view_pdp_picture_test_wizard_form" model="ir.ui.view">
    <field name="name">pdp.picture.test.wizard.form</field>
    <field name="model">pdp.picture.test.wizard</field>
    <field name="arch" type="xml">
      <form string="Test Picture" create="false" edit="true">
        <sheet>
          <group>
            <field name="model_id" options="{'no_create': True}"/>
            <field name="filename" readonly="1"/>
          </group>
          <group>
            <field name="image" widget="image"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_pdp_picture_test_wizard" model="ir.actions.act_window">
    <field name="name">Test Picture</field>
    <field name="res_model">pdp.picture.test.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
    <field name="context">{}</field>
  </record>

  <!-- Menu sous le menu PDP Pictures -->
  <menuitem id="menu_pdp_picture_test"
            name="Test Picture"
            parent="pdp_picture.menu_pdp_picture_root"
            action="action_pdp_picture_test_wizard"
            sequence="99"/>
</odoo>
