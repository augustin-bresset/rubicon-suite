<odoo>
    <record id="view_price_addon_list" model="ir.ui.view">
        <field name="name">pdp.price.addon.list</field>
        <field name="model">pdp.price.addon</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_code"/>
                <field name="cost"/>
                <field name="currency"/>
            </list>
        </field>
    </record>

    <record id="view_price_addon_form" model="ir.ui.view">
        <field name="name">pdp.price.addon.form</field>
        <field name="model">pdp.price.addon</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_code"/>
                        <field name="currency"/>
                        <field name="cost" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_price_addon" model="ir.actions.act_window">
        <field name="name">Addon Prices</field>
        <field name="res_model">pdp.price.addon</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
