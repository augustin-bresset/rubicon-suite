<!-- views/pdp_views.xml -->
<odoo>
  <record id="pdp_product_form_inherit_price_preview" model="ir.ui.view">
    <field name="name">pdp.product.form.price.preview.button</field>
    <field name="model">pdp.product</field>
    <field name="inherit_id" ref="pdp_product.view_pdp_product_form"/> <!-- adapte l'id -->
    <field name="arch" type="xml">
      <header position="inside">
        <button name="%(action_pdp_price_preview)d"
                type="action"
                context="{'default_product_id': active_id}"
                string="Preview Price"
                class="btn-secondary"/>
      </header>
    </field>
  </record>
</odoo>
