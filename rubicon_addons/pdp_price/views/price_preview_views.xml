<odoo>
  <!-- Form view du wizard -->
  <record id="view_pdp_price_preview_form" model="ir.ui.view">
    <field name="name">pdp.price.preview.form</field>
    <field name="model">pdp.price.preview</field>
    <field name="arch" type="xml">
      <form string="Price Preview" create="false" edit="true">
        <header>
          <button name="action_compute" type="object" string="Compute" class="btn-primary"/>
          <button name="action_save" type="object" string="Save" class="btn-secondary"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="product_id"/>
              <field name="margin_id"/>
            </group>
            <group>
              <field name="date"/>
              <field name="currency_id"/>
            </group>
          </group>
          <group>
            <field name="line_ids" nolabel="1">
              <list editable="bottom">
                <field name="type"/>
                <field name="cost"/>
                <field name="margin"/>
                <field name="price"/>
                <field name="warnings" optional="show" decoration-danger="warnings" column_invisible="not parent.cost"/>
              </list>
            </field>
          </group>
          <group>
            <field name="cost" readonly="1"/>
            <field name="margin" readonly="1"/>
            <field name="price" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action fenêtre du wizard -->
  <record id="action_pdp_price_preview_wizard" model="ir.actions.act_window">
    <field name="name">Price Preview</field>
    <field name="res_model">pdp.price.preview</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="context">{}</field>
  </record>
</odoo>
