<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="view_pdp_price_preview_wizard_form" model="ir.ui.view">
    <field name="name">pdp.price.preview.wizard.form</field>
    <field name="model">pdp.price.preview.wizard</field>
    <field name="arch" type="xml">
      <form string="Price Preview" create="false" edit="false">
        <sheet>
          <group>
            <group>
              <field name="product_id"/>
              <field name="margin_id"/>
            </group>
            <group>
              <field name="date"/>
              <field name="currency_id"/>
            </group>
          </group>

          <!-- PAS DE <tree> ICI : on laisse Odoo auto-générer -->
          <field name="line_ids"
                 nolabel="1"
                 readonly="1"
                 create="0" edit="0" delete="0"/>

          <footer>
            <button string="Close" special="cancel" class="btn-secondary"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_pdp_price_preview_wizard" model="ir.actions.act_window">
    <field name="name">Price Preview</field>
    <field name="res_model">pdp.price.preview.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>


</odoo>
