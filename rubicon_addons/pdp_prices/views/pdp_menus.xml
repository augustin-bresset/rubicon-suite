<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Root menu for PDP -->
  <menuitem id="menu_pdp_root" name="PDP Stone" sequence="10"/>

  <!-- Stone Category -->
  <record id="action_pdp_stone_category" model="ir.actions.act_window">
    <field name="name">Stone Categories</field>
    <field name="res_model">pdp.stone.category</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_category"
            name="Categories"
            parent="menu_pdp_root"
            action="action_pdp_stone_category"
            sequence="1"/>

  <!-- Stone Type -->
  <record id="action_pdp_stone_type" model="ir.actions.act_window">
    <field name="name">Stone Types</field>
    <field name="res_model">pdp.stone.type</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_type"
            name="Types"
            parent="menu_pdp_root"
            action="action_pdp_stone_type"
            sequence="2"/>

  <!-- Stone Size -->
  <record id="action_pdp_stone_size" model="ir.actions.act_window">
    <field name="name">Stone Sizes</field>
    <field name="res_model">pdp.stone.size</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_size"
            name="Sizes"
            parent="menu_pdp_root"
            action="action_pdp_stone_size"
            sequence="3"/>

  <!-- Stone Shape -->
  <record id="action_pdp_stone_shape" model="ir.actions.act_window">
    <field name="name">Stone Shapes</field>
    <field name="res_model">pdp.stone.shape</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_shape"
            name="Shapes"
            parent="menu_pdp_root"
            action="action_pdp_stone_shape"
            sequence="4"/>

  <!-- Stone Shade -->
  <record id="action_pdp_stone_shade" model="ir.actions.act_window">
    <field name="name">Stone Shades</field>
    <field name="res_model">pdp.stone.shade</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_shade"
            name="Shades"
            parent="menu_pdp_root"
            action="action_pdp_stone_shade"
            sequence="5"/>

  <!-- Stone Weight -->
  <record id="action_pdp_stone_weight" model="ir.actions.act_window">
    <field name="name">Stone Weights</field>
    <field name="res_model">pdp.stone.weight</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_weight"
            name="Weights"
            parent="menu_pdp_root"
            action="action_pdp_stone_weight"
            sequence="5"/>


  <!-- Stone Item -->
  <record id="action_pdp_stone_item" model="ir.actions.act_window">
    <field name="name">Stone Items</field>
    <field name="res_model">pdp.stone.item</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_stone_item"
            name="Items"
            parent="menu_pdp_root"
            action="action_pdp_stone_item"
            sequence="5"/>

</odoo>
