<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Root menu for PDP -->
  <menuitem id="menu_pdp_root" name="PDP Product" sequence="10"/>

  <!-- product category -->
  <record id="action_pdp_product_category" model="ir.actions.act_window">
    <field name="name">Product Category</field>
    <field name="res_model">pdp.product.category</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_category"
            name="Categories"
            parent="menu_pdp_root"
            action="action_pdp_product_category"
            sequence="1"/>

  <!-- model  -->
  <record id="action_pdp_product_model" model="ir.actions.act_window">
    <field name="name">Product Model</field>
    <field name="res_model">pdp.product.model</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_model"
            name="Models"
            parent="menu_pdp_root"
            action="action_pdp_product_model"
            sequence="1"/>

  <!-- model matching  -->
  <record id="action_pdp_product_model_matching" model="ir.actions.act_window">
    <field name="name">Product Model Matching</field>
    <field name="res_model">pdp.product.model.matching</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_model_matching"
            name="Model Matching"
            parent="menu_pdp_root"
            action="action_pdp_product_model_matching"
            sequence="1"/>

  <!-- model metal  -->
  <record id="action_pdp_product_model_metal" model="ir.actions.act_window">
    <field name="name">Product Model Metal</field>
    <field name="res_model">pdp.product.model.metal</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_model_metal"
            name="Model metal"
            parent="menu_pdp_root"
            action="action_pdp_product_model_metal"
            sequence="1"/>


  <!-- Product Parts -->
  <record id="action_pdp_product_part" model="ir.actions.act_window">
    <field name="name">Product Part</field>
    <field name="res_model">pdp.product.part</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_part"
            name="Parts"
            parent="menu_pdp_root"
            action="action_pdp_product_part"
            sequence="1"/>



  <!-- Product Stone -->
  <record id="action_pdp_product_stone" model="ir.actions.act_window">
    <field name="name">Product Stones</field>
    <field name="res_model">pdp.product.stone</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_stone"
            name="Stones"
            parent="menu_pdp_root"
            action="action_pdp_product_stone"
            sequence="1"/>



  <!-- Products -->
  <record id="action_pdp_product" model="ir.actions.act_window">
    <field name="name">Product </field>
    <field name="res_model">pdp.product</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product"
            name="Products"
            parent="menu_pdp_root"
            action="action_pdp_product"
            sequence="1"/>

  <!-- Product Stone Composition -->
  <record id="action_pdp_product_stone_composition" model="ir.actions.act_window">
    <field name="name">Product </field>
    <field name="res_model">pdp.product.stone.composition</field>
    <field name="view_mode">list,form</field>
  </record>
  <menuitem id="menu_pdp_product_stone_composition"
            name="Product Stone Composition"
            parent="menu_pdp_root"
            action="action_pdp_product_stone_composition"
            sequence="1"/>

</odoo>
