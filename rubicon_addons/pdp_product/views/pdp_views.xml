<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Product Category -->
  <record id="view_pdp_product_category_list" model="ir.ui.view">
    <field name="name">pdp.product.category.list</field>
    <field name="model">pdp.product.category</field>
    <field name="arch" type="xml">
      <list string="Product Categories">
        <field name="code"/>
        <field name="name"/>
        <field name="waste"/>
      </list>
    </field>
  </record>

 <!-- Product Models -->
  <record id="view_pdp_product_model_list" model="ir.ui.view">
    <field name="name">pdp.product.model.list</field>
    <field name="model">pdp.product.model</field>
    <field name="arch" type="xml">
      <list string="Product Models">
        <field name="code"/>
        <field name="parent_model_id"/>
        <field name="drawing"/>
        <field name="quotation"/>

      </list>
    </field>
  </record>


   <!-- Product Matching -->
  <record id="view_pdp_product_model_matching_list" model="ir.ui.view">
    <field name="name">pdp.product.model.matching.list</field>
    <field name="model">pdp.product.model.matching</field>
    <field name="arch" type="xml">
      <list string="Matching Models">
        <field name="model_one_id"/>
        <field name="model_two_id"/>
      </list>
    </field>
  </record>

  <!-- Model Metal -->
  <record id="view_pdp_product_model_metal_list" model="ir.ui.view">
    <field name="name">pdp.product.model.metal.list</field>
    <field name="model">pdp.product.model.metal</field>
    <field name="arch" type="xml">
      <list string="Metal Models">
        <field name="model_id"/>
        <field name="metal_id"/>
        <field name="metal_version"/>
        <field name="purity_id"/>
        <field name="weight"/>
        
      </list>
    </field>
  </record>

  <!-- Product -->
  <record id="view_pdp_product_list" model="ir.ui.view">
    <field name="name">pdp.product.list</field>
    <field name="model">pdp.product</field>
    <field name="arch" type="xml">
      <list string="Products">
        <field name="code"/>
        <field name="category_id"/>
        <field name="model_id"/>
        <field name="stone_composition_id"/>
        <field name="metal"/>
        <field name="active"/>
        <field name="in_collection"/>
        <field name="create_date"/>
        <field name="remark"/>
        <field name="part_ids"/>
      </list>
    </field>
  </record>

  <!-- Product Part -->
  <record id="view_pdp_product_part_list" model="ir.ui.view">
    <field name="name">pdp.product.part.list</field>
    <field name="model">pdp.product.part</field>
    <field name="arch" type="xml">
      <list string="Product Part">
        <field name="product_id"/>
        <field name="part_id"/>
      </list>
    </field>
  </record>

  <!-- Product Stone -->
  <record id="view_pdp_product_stone_list" model="ir.ui.view">
    <field name="name">pdp.product.stone.list</field>
    <field name="model">pdp.product.stone</field>
    <field name="arch" type="xml">
      <list string="Product Stone">
        <field name="pieces"/>
        <field name="composition_id"/>
        <field name="stone_id"/>
        <field name="weight"/>
        <field name="reshaped_shape_id"/>
        <field name="reshaped_size_id"/>
        <field name="reshaped_weight"/>
      </list>
    </field>
  </record>

  <!-- Product Stone Composition -->
  <record id="view_pdp_product_stone_composition_list" model="ir.ui.view">
    <field name="name">pdp.product.stone.composition.list</field>
    <field name="model">pdp.product.stone.composition</field>
    <field name="arch" type="xml">
      <list string="Product Stone Composition">
        <field name="code"/>
        <field name="stone_line_ids"/>
      </list>
    </field>
  </record>

</odoo>
