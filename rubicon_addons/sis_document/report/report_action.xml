<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_sis_document" model="ir.actions.report">
        <field name="name">SIS Document</field>
        <field name="model">sis.document</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sis_document.report_sis_document</field>
        <field name="report_file">sis_document.report_sis_document</field>
        <field name="print_report_name">(object.doc_type_id.name or 'Document') + '_' + (object.name or '').replace('/', '_')</field>
        <field name="binding_model_id" ref="model_sis_document"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
</odoo>
