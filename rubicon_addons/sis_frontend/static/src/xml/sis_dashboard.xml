<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="sis_frontend.SisDashboard" owl="1">
        <div class="sis_dashboard w-100 h-100 bg-light d-flex flex-column align-items-center justify-content-center">

            <div class="text-center mb-5">
                <h1 class="display-4 text-secondary mb-2" style="font-weight: 300; letter-spacing: 1px;">Sales Information System (SIS)</h1>
                <p class="text-muted">Rubicon Integrated Edition</p>
            </div>

            <div class="container" style="max-width: 900px;">
                <div class="row g-4 justify-content-center">

                    <!-- Parties -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm border-0 sis-card" t-on-click="() => this.openAction('sis_party.action_sis_parties')">
                            <div class="card-body text-center p-5 d-flex flex-column align-items-center justify-content-center">
                                <i class="fa fa-users fa-5x text-primary mb-4"></i>
                                <h3 class="card-title text-dark text-uppercase fw-bold" style="letter-spacing: 2px;">PARTIES</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Quotation -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm border-0 sis-card" t-on-click="() => this.openAction('sis_document.action_sis_quotations')">
                            <div class="card-body text-center p-5 d-flex flex-column align-items-center justify-content-center">
                                <i class="fa fa-file-text-o fa-5x text-info mb-4"></i>
                                <h3 class="card-title text-dark text-uppercase fw-bold" style="letter-spacing: 2px;">QUOTATION</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Book Orders -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm border-0 sis-card" t-on-click="() => this.openAction('sis_document.action_sis_orders')">
                            <div class="card-body text-center p-5 d-flex flex-column align-items-center justify-content-center">
                                <i class="fa fa-shopping-cart fa-5x text-success mb-4"></i>
                                <h3 class="card-title text-dark text-uppercase fw-bold" style="letter-spacing: 2px;">BOOK ORDERS</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Ship Goods -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 shadow-sm border-0 sis-card" t-on-click="() => this.openAction('sis_document.action_sis_invoices')">
                            <div class="card-body text-center p-5 d-flex flex-column align-items-center justify-content-center">
                                <i class="fa fa-ship fa-5x text-warning mb-4"></i>
                                <h3 class="card-title text-dark text-uppercase fw-bold" style="letter-spacing: 2px;">SHIP GOODS</h3>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </t>
</templates>
