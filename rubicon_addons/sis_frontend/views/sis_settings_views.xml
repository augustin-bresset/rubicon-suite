<odoo>
    <!-- Standalone SIS Settings form -->
    <record id="view_sis_settings_form" model="ir.ui.view">
        <field name="name">sis.settings.form.standalone</field>
        <field name="model">res.config.settings</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="SIS Settings" create="0" delete="0">
                <sheet>
                    <group string="Developer Access">
                        <field name="group_sis_odoo_manager"
                               widget="boolean_toggle"
                               string="Odoo Manager"/>
                        <div colspan="2" class="text-muted small">
                            When enabled, module-level menus (SIS Party, SIS Document)
                            become visible in the app switcher for all internal users.
                            The page will reload after saving.
                        </div>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" type="object" name="execute" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action that opens the SIS-specific settings form -->
    <record id="action_sis_settings" model="ir.actions.act_window">
        <field name="name">SIS Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_sis_settings_form"/>
        <field name="target">current</field>
    </record>
</odoo>
